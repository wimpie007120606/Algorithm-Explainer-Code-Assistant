# ─── LLM Provider ────────────────────────────────────────────────────────────
# Supported values: openai | gemini
LLM_PROVIDER=openai

# ─── API Keys ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                   # Required for OpenAI provider
GEMINI_API_KEY=                         # Only needed if LLM_PROVIDER=gemini

# ─── Model Selection ─────────────────────────────────────────────────────────
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# Gemini: gemini-1.5-pro, gemini-1.5-flash
CHAT_MODEL=gpt-4o-mini

# ─── Embeddings ───────────────────────────────────────────────────────────────
# OpenAI: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002
# Gemini: models/embedding-001
EMBEDDING_MODEL=text-embedding-3-small

# ─── Vector Database ──────────────────────────────────────────────────────────
# Supported values: chroma | pinecone
VECTOR_DB=chroma
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=algorithm_docs

# Pinecone (only needed if VECTOR_DB=pinecone)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=algorithm-rag
PINECONE_ENVIRONMENT=

# ─── Data Paths ───────────────────────────────────────────────────────────────
DATA_RAW_DIR=./data/raw
DATA_PROCESSED_DIR=./data/processed

# ─── Retrieval Settings ───────────────────────────────────────────────────────
DEFAULT_TOP_K=4
SIMILARITY_THRESHOLD=0.3

# ─── Chunking Settings ────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# ─── LLM Generation Settings ─────────────────────────────────────────────────
TEMPERATURE=0.0
MAX_TOKENS=2048

# ─── Application ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
